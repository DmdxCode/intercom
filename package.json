{
  "name": "pollnet",
  "version": "1.0.0",
  "description": "Decentralized P2P polling agent built on Intercom (Trac Network)",
  "main": "index.js",
  "type": "commonjs",
  "pear": {
    "name": "pollnet",
    "type": "terminal"
  },
  "scripts": {
    "start": "pear run --tmp-store --no-pre . --peer-store-name admin --msb-store-name admin-msb --subnet-channel pollnet-v1"
  },
  "dependencies": {
    "intercom": "github:Trac-Systems/intercom"
  },
  "overrides": {
    "trac-wallet": "1.0.1"
  },
  "keywords": [
    "trac",
    "intercom",
    "p2p",
    "polling",
    "voting",
    "agents",
    "pear"
  ],
  "license": "MIT"
}